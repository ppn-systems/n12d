@namespace Nalix.Dashboard.Components.Pages
@page "/metrics/connections"
@inherits MetricPageBase

<PageTitle>Connections — Nalix</PageTitle>

@if (IsLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-0" />
}

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="metrics-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="metrics-toolbar" Spacing="2">
        <MudIcon Icon="@Icons.Material.Outlined.Cable" Color="Color.Primary" />
        <MudText Typo="Typo.h5">Connections</MudText>
        @if (IsStale)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Stale</MudChip>
        }
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Outlined.Refresh" Size="Size.Small"
                       OnClick="ManualRefreshAsync" title="Refresh" />
        <MudIconButton Icon="@(Polling.IsPaused ? Icons.Material.Outlined.PlayArrow : Icons.Material.Outlined.Pause)"
                       Size="Size.Small"
                       OnClick="@(Polling.IsPaused ? Resume : Pause)"
                       title="@(Polling.IsPaused ? "Resume" : "Pause")" />
    </MudStack>

    @{
        var report = Snapshot is null ? null
            : Parsers.Parse<Nalix.Dashboard.Domain.Reports.Connections.ConnectionsReport>(Target, Snapshot.ObservationData);
    }

    @if (Snapshot is null)
    {
        <MudAlert Severity="Severity.Info">Waiting for data…</MudAlert>
    }
    else if (report is null)
    {
        <MudAlert Severity="Severity.Warning">Could not parse connections report.</MudAlert>
    }
    else
    {
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" md="3">
                <MetricTile Label="Total Connections" Value="@MetricFormat.Count(report.TotalConnections)" Detail="Across all shards" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MetricTile Label="Shard Count" Value="@MetricFormat.Count(report.ShardCount)" Detail="Connection hub shards" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MetricTile Label="Bytes Sent" Value="@MetricFormat.Bytes(report.TotalBytesSent)" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MetricTile Label="Bytes Received" Value="@MetricFormat.Bytes(report.TotalBytesReceived)" />
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="3" Class="mt-1">
            <MudItem xs="12" sm="6" md="6">
                <MetricTile Label="Ingress Throughput" Value="@($"{MetricFormat.Bytes(report.IngressBytesPerSecond)}/s")" />
            </MudItem>
            <MudItem xs="12" sm="6" md="6">
                <MetricTile Label="Egress Throughput" Value="@($"{MetricFormat.Bytes(report.EgressBytesPerSecond)}/s")" />
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    protected override RuntimeObservationTarget Target => RuntimeObservationTarget.CONNECTIONS;
    protected override string Route => "/metrics/connections";
}
