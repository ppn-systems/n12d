@namespace Nalix.Dashboard.Components.Pages
@page "/"
@inject IDashboardStateReader State
@inject IAdminSettingsStore SettingsStore
@inject IAdminClient Client
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Overview — Nalix</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
    <MudText Typo="Typo.h5" GutterBottom="true">Overview</MudText>

    <MudGrid Spacing="3" Class="metrics-grid">
        <MudItem xs="12" sm="6" md="3">
            <MetricTile Label="Status"
                        Value="@(State.IsConnected ? "Connected" : "Disconnected")"
                        ValueColor="@(State.IsConnected ? Color.Success : Color.Error)"
                        Detail="WebSocket session" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MetricTile Label="Latency"
                        Value="@(State.LastPingMilliseconds.HasValue ? $"{State.LastPingMilliseconds:F1} ms" : "-")"
                        Detail="@(State.LastPingAt is { } at ? at.LocalDateTime.ToString("HH:mm:ss") : "No ping yet")" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MetricTile Label="Cached Reports" Value="@($"{State.Reports.Count} / 13")" Detail="Report targets" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MetricTile Label="Log Entries" Value="@MetricFormat.Count(State.Logs.Count)" Detail="Activity rows" />
        </MudItem>
    </MudGrid>

    <MudDivider Class="my-5" />

    <MudText Typo="Typo.h6" GutterBottom="true">Metric Pages</MudText>
    <MudGrid Spacing="2">
        @foreach (NavItem item in _metrics)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Class="pa-3" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@item.Icon" Color="Color.Primary" />
                        <MudLink Href="@item.Route" Typo="Typo.subtitle1" Color="Color.Default">
                            @item.Title
                        </MudLink>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    @if (State.Logs.Count > 0)
    {
        <MudDivider Class="my-5" />
        <MudText Typo="Typo.h6" GutterBottom="true">Recent Activity</MudText>
        <MudPaper Elevation="1" Class="pa-3" Style="font-family: monospace; font-size: 0.78rem; max-height: 240px; overflow-y: auto;">
            @foreach (DashboardLogEntry entry in State.Logs.TakeLast(15).Reverse())
            {
                <div class="@($"log-line log-{entry.Level.ToLowerInvariant()}")">
                    [@entry.Timestamp.LocalDateTime.ToString("HH:mm:ss")] [@entry.Level] @entry.Message
                </div>
            }
        </MudPaper>
    }
</MudContainer>

@code {
    private static readonly IReadOnlyList<NavItem> _metrics =
        AppNavigation.Build(PermissionLevel.SUPERVISOR)[1].Items;

    protected override async Task OnInitializedAsync()
    {
        if (!State.HasApiKey)
        {
            string? savedKey = await SettingsStore.GetApiKeyAsync().ConfigureAwait(false);
            if (!string.IsNullOrWhiteSpace(savedKey))
            {
                await Client.SetApiKeyAsync(savedKey).ConfigureAwait(false);
            }
            else
            {
                Nav.NavigateTo("/login");
                return;
            }
        }

        State.Changed += OnStateChanged;
    }

    public void Dispose() => State.Changed -= OnStateChanged;

    private void OnStateChanged() => _ = InvokeAsync(StateHasChanged);
}
